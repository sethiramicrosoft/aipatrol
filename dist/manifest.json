{
  "manifest_version": 3,
  "name": "GuardPrompt",
  "version": "1.0.0",
  "description": "Protect sensitive data before it reaches AI tools. Detects API keys, credentials, PII and more.",

  "permissions": [
    "storage",
    "notifications"
  ],

  "host_permissions": [
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://www.perplexity.ai/*",
    "*://perplexity.ai/*",
    "*://copilot.microsoft.com/*",
    "*://you.com/*",
    "*://poe.com/*",
    "*://www.google.com/*",
    "*://www.bing.com/*",
    "*://localhost/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://www.perplexity.ai/*",
        "*://perplexity.ai/*",
        "*://copilot.microsoft.com/*",
        "*://you.com/*",
        "*://poe.com/*",
        "*://www.google.com/*",
        "*://www.bing.com/*",
        "*://localhost/*"
      ],
      "js": ["content/interceptor.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
